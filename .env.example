# Time-Off Microservice — Environment Configuration
# Copy this file to .env and fill in values for your environment

# ── HCM Integration ───────────────────────────────────────────────────────────
HCM_BASE_URL=http://localhost:4000
HCM_API_KEY=mock-api-key
HCM_TIMEOUT_MS=5000

# ── Database ──────────────────────────────────────────────────────────────────
# Use :memory: for tests, or a file path for persistent storage
DB_PATH=time-off.db

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Mock HCM Server ───────────────────────────────────────────────────────────
MOCK_HCM_PORT=4000
